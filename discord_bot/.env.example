# discord_bot/.env.example
# このファイルをコピーして .env を作成してください。
# cp .env.example .env
#
# 本ファイルはリポジトリに含まれます（サンプルとして）。
# 実際の .env ファイルは .gitignore で除外されています。

# ----------------------------------------
# Discord Bot
# ----------------------------------------
# 管理者ユーザー ID (DM 送信先)
ADMIN_USER_ID=000000000000000000
# Bot を登録するギルド (サーバー) の ID
GUILD_ID=000000000000000000

# Discord OAuth2
DISCORD_CLIENT_ID=bot_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=[https://dashboard.awajiempire.net/callback](https://dashboard.awajiempire.net/callback)

# Web Dashboard URL (Bot案内用)
DASHBOARD_URL=https://dashboard.awajiempire.net

# ★追加: AFK監視設定
TARGET_USER_ID=target_user_id #監視対象ユーザー
ACTIVE_START_HOUR=ACTIVE_START_HOUR #稼働開始時間
ACTIVE_END_HOUR=ACTIVE_END_HOUR #稼働終了時間
AFK_TIMEOUT_SECONDS=AFK_TIMEOUT_SECONDS #AFKタイムアウト時間（秒）
REPORT_CHANNEL_NAME=REPORT_CHANNEL_NAME #レポート送信先チャンネル名


# ----------------------------------------
# Database (MariaDB)
# ----------------------------------------
DB_HOST=127.0.0.1
DB_NAME=bot_db
DB_USER=root
DB_PASS=

# ----------------------------------------
# Rust Bridge (database_bridge)
# ----------------------------------------
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8088

# ----------------------------------------
# 権限マスミュート機能
# カンマ区切りでチャンネル名を列挙する。
# ----------------------------------------
# [通知抑制のみ] 送信は許可するが @mention・Webhook は禁止するチャンネル
MUTE_ONLY_CHANNEL_NAMES=配信コメント

# [閲覧専用] 送信・@mention・Webhook をすべて禁止するチャンネル
READ_ONLY_MUTE_CHANNEL_NAMES=参加ログ

# ----------------------------------------
# Cloudflare Zero Trust (Secure Lobby)
# ----------------------------------------
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CF_ACCESS_CLIENT_ID=your_service_token_id_here
CF_ACCESS_CLIENT_SECRET=your_service_token_secret_here
